# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — optional. AI features hide gracefully when missing.
OPENAI_API_KEY=

# Demo identity. The seed script creates this user via service-role.
# All seeded stations are owned by this email.
DEMO_USER_EMAIL=demo@agent-republics.local
DEMO_USER_PASSWORD=republic-demo-2026

# Admin gate. The user signed in with this email gets access to /admin
# pages and the /api/admin/* endpoints. Leave blank in dev to disable
# admin entirely (no one can approve signups). Set to your email in
# production.
ADMIN_EMAIL=

# Public base URL of THIS Next.js deployment. Used by server actions
# that POST back to /api routes via fetch (e.g. signup). For local dev
# this is http://localhost:3000. For production, your real domain.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
